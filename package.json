{
  "name": "zippi",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"npm run dev -w zippi-frontend\" \"npm run dev -w zippi-backend\"",
    "dev:frontend": "npm run dev -w zippi-frontend",
    "dev:backend": "npm run dev -w zippi-backend",
    "build": "npm run build -w zippi-frontend",
    "start:backend": "npm run start -w zippi-backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
