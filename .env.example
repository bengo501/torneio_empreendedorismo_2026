# copie para .env e preencha as chaves (nunca commitar .env)

# sympla — minha conta → integrações → criar chave de acesso
# https://www.sympla.com.br/
VITE_SYMPLA_TOKEN=
VITE_SYMPLA_PROXY=/api/sympla

# google maps — exige cartão no cadastro; opcional
# VITE_GOOGLE_MAPS_API_KEY=

# geoapify — cadastro grátis sem cartão: https://www.geoapify.com/
VITE_GEOAPIFY_API_KEY=

# locationiq — https://locationiq.com/ (free tier)
# VITE_LOCATIONIQ_TOKEN=

# openrouteservice — https://openrouteservice.org/dev/
# VITE_ORS_API_KEY=

# micromobilidade (gbfs / parceiros — quando houver contrato)
VITE_WHOOSH_API_KEY=
VITE_LIME_PARTNER_TOKEN=
VITE_TEMBICI_API_KEY=

# transporte por app — uber/99 não têm api pública de preço; ver docs/CHAVES_API.md
# VITE_UBER_CLIENT_ID=        # só parceria uber for developers (b2b)
# VITE_99_API_KEY=             # não disponível para terceiros
